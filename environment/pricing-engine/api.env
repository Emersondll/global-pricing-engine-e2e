# uat hosts
PRICE_HOST=https://services-uat.bees-platform.dev/api/price-service
DEAL_HOST=https://services-uat.bees-platform.dev/api/deal-service
CHARGE_HOST=https://services-uat.bees-platform.dev/api/charge-service
ENFORCEMENT_HOST=https://services-uat.bees-platform.dev/api/enforcement-service
ACCOUNT_HOST=https://services-uat.bees-platform.dev/v1/accounts
ITEM_HOST=https://services-uat.bees-platform.dev/api/items
COMBO_HOST=https://services-uat.bees-platform.dev/api/combos
EMPTIES_HOST=https://services-uat.bees-platform.dev/v1/empties-service
DELIVERY_WINDOW_HOST=https://services-uat.bees-platform.dev/v1/delivery-windows
VENDOR_CONFIG_HOST=https://services-uat.bees-platform.dev/v1/vendors

# UAT price configuration
ENABLE_JWT_VALIDATION=ar,br,ca,cl,co,de,do,ec,gb,hn,kr,mx,pa,pe,py,sv,tz,ug,us,uy,za
ENABLE_EXTRA_EMPTY_DISCOUNT=co,ec,hn,nl,sv
ENABLE_ENFORCEMENT_SERVICE_INTEGRATION=ar,br,co,mx,nl,pa,pe
ENABLE_HACK_EXTRA_EMPTY=co
ENABLE_SIMULATION_WITHOUT_PAYMENT_METHOD=ca
ENABLE_ACCOUNTS_INTEGRATION=br,bo,co,de,do,ec,hn,mx,pa,pe,sv,tz,ug
ENABLE_COMBOS_3POCM=br
ENABLE_ITEM_SERVICE_CALL_FOR_PRICE_PER_UOM=br,co
ENABLE_FORCE_LINE_ITEM_DISCOUNT_STRATEGY_BEST=ca,do
ENABLE_ENFORCEMENT_SERVICE_INTEGRATION_V2=ar,br,co,mx,nl,pe
ENABLE_DELIVERY_WINDOW_SERVICE_INTEGRATION=br,do,nl,pe
REQUEST_BODY_ITEMS_LIMIT=50
REST_TIMEOUT_REQUEST_SERVICE=12000

# code toggle ON
BEESPR_14039=true
BEESPR_18293=true
